+//! Exports differential test vectors for external reimplementations of
+//! leanVM's Poseidon16 (classic Poseidon over KoalaBear, width 16,
+//! 4 + 20 + 4 rounds, x^3 S-box, circulant MDS, compress = permute + input).
+//!
+//! Run: cargo test -p koala-bear --release export_poseidon16_vectors -- --nocapture
+//! JSON is printed between VECTORS_BEGIN / VECTORS_END markers.
+
+use std::sync::OnceLock;
+
+use field::PrimeField32;
+use koala_bear::{KoalaBear, Poseidon1KoalaBear16, default_koalabear_poseidon1_16, symmetric::Permutation};
+
+fn perm16() -> &'static Poseidon1KoalaBear16 {
+    static P: OnceLock<Poseidon1KoalaBear16> = OnceLock::new();
+    P.get_or_init(default_koalabear_poseidon1_16)
+}
+
+/// Same as symetric::poseidon16_compress: permute + feed-forward, first 8 lanes.
+fn poseidon16_compress(input: [KoalaBear; 16]) -> [KoalaBear; 8] {
+    let mut state = input;
+    perm16().compress_in_place(&mut state);
+    state[0..8].try_into().unwrap()
+}
+
+/// Deterministic field elements from a simple LCG (no rand dependency).
+struct Lcg(u64);
+impl Lcg {
+    fn next_fe(&mut self) -> KoalaBear {
+        self.0 = self.0.wrapping_mul(6364136223846793005).wrapping_add(1442695040888963407);
+        KoalaBear::new(((self.0 >> 16) % 0x7f000001 as u64) as u32)
+    }
+    fn next_state(&mut self) -> [KoalaBear; 16] {
+        core::array::from_fn(|_| self.next_fe())
+    }
+    fn next_digest(&mut self) -> [KoalaBear; 8] {
+        core::array::from_fn(|_| self.next_fe())
+    }
+}
+
+fn j16(x: &[KoalaBear; 16]) -> String {
+    let v: Vec<String> = x.iter().map(|e| e.as_canonical_u32().to_string()).collect();
+    format!("[{}]", v.join(","))
+}
+fn j8(x: &[KoalaBear; 8]) -> String {
+    let v: Vec<String> = x.iter().map(|e| e.as_canonical_u32().to_string()).collect();
+    format!("[{}]", v.join(","))
+}
+
+/// The pool's tagged hash: compress(tag_block, compress(a, b)), tag in slot 0.
+fn tagged(tag: u32, a: &[KoalaBear; 8], b: &[KoalaBear; 8]) -> [KoalaBear; 8] {
+    let mut inner_in = [KoalaBear::new(0); 16];
+    inner_in[..8].copy_from_slice(a);
+    inner_in[8..].copy_from_slice(b);
+    let inner = poseidon16_compress(inner_in);
+    let mut outer_in = [KoalaBear::new(0); 16];
+    outer_in[0] = KoalaBear::new(tag);
+    outer_in[8..].copy_from_slice(&inner);
+    poseidon16_compress(outer_in)
+}
+
+fn h8(a: &[KoalaBear; 8], b: &[KoalaBear; 8]) -> [KoalaBear; 8] {
+    let mut x = [KoalaBear::new(0); 16];
+    x[..8].copy_from_slice(a);
+    x[8..].copy_from_slice(b);
+    poseidon16_compress(x)
+}
+
+#[test]
+fn export_poseidon16_vectors() {
+    let perm = perm16();
+    let mut out = String::from("{\n");
+
+    // permutation vectors: zero state, unit states, LCG states
+    let mut cases: Vec<[KoalaBear; 16]> = vec![[KoalaBear::new(0); 16]];
+    let mut e1 = [KoalaBear::new(0); 16];
+    e1[0] = KoalaBear::new(1);
+    cases.push(e1);
+    cases.push(core::array::from_fn(|i| KoalaBear::new(i as u32)));
+    let mut lcg = Lcg(42);
+    for _ in 0..29 {
+        cases.push(lcg.next_state());
+    }
+    out.push_str("\"permute\":[");
+    for (i, c) in cases.iter().enumerate() {
+        let y = perm.permute(*c);
+        if i > 0 { out.push(','); }
+        out.push_str(&format!("{{\"in\":{},\"out\":{}}}", j16(c), j16(&y)));
+    }
+    out.push_str("],\n");
+
+    // compress vectors (16 -> 8, feed-forward then truncate)
+    out.push_str("\"compress\":[");
+    for (i, c) in cases.iter().enumerate() {
+        let y = poseidon16_compress(*c);
+        if i > 0 { out.push(','); }
+        out.push_str(&format!("{{\"in\":{},\"out\":{}}}", j16(c), j8(&y)));
+    }
+    out.push_str("],\n");
+
+    // pool-shaped chain: owner_pk / cm / nf / claim from seeded secrets
+    // (mirrors circuits/spend.py: TAG_PK=1, TAG_LEAF=2, TAG_NULL=3, TAG_CLAIM=4)
+    let mut lcg = Lcg(2026);
+    let spend_key = lcg.next_digest();
+    let rho = lcg.next_digest();
+    let root = lcg.next_digest();
+    let out_cm = lcg.next_digest();
+    let ctx = lcg.next_digest();
+    let zero8 = [KoalaBear::new(0); 8];
+    let owner_pk = tagged(1, &spend_key, &zero8);
+    let cm = tagged(2, &owner_pk, &rho);
+    let nf = tagged(3, &spend_key, &cm);
+    let claim = tagged(4, &h8(&root, &nf), &h8(&out_cm, &ctx));
+    out.push_str(&format!(
+        "\"pool_chain\":{{\"spend_key\":{},\"rho\":{},\"root\":{},\"out_cm\":{},\"ctx\":{},\"owner_pk\":{},\"cm\":{},\"nf\":{},\"claim\":{}}}\n",
+        j8(&spend_key), j8(&rho), j8(&root), j8(&out_cm), j8(&ctx),
+        j8(&owner_pk), j8(&cm), j8(&nf), j8(&claim)
+    ));
+    out.push('}');
+
+    println!("VECTORS_BEGIN\n{}\nVECTORS_END", out);
+}
